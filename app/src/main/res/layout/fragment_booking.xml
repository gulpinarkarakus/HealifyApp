<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FA">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardProfile"
            android:layout_width="120dp"
            android:layout_height="140dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgDoctor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/drawable_botoks" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/cardProfile"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cardProfile"
            app:layout_constraintTop_toTopOf="@id/cardProfile">

            <TextView
                android:id="@+id/bookingDoctorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prof. Dr. Ahmet Yılmaz"
                android:textColor="#1A1A1A"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bookingDoctorTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="KBB Uzmanı"
                android:textColor="#3A7BD5"
                android:textSize="18sp" />
        </LinearLayout>

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="30dp"
            android:background="#D1D1D1"
            app:layout_constraintTop_toBottomOf="@id/cardProfile" />

        <TextView
            android:id="@+id/lblCv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="PROFESYONEL ÖZGEÇMİŞ"
            android:textColor="#3A7BD5"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toBottomOf="@id/divider" />

        <TextView
            android:id="@+id/bookingDoctorCV"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="8dp"
            android:text="Doktorun detaylı geçmişi buraya gelecek..."
            android:textColor="#444444"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/lblCv" />

        <TextView
            android:id="@+id/lblInstitutions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="35dp"
            android:text="ÇALIŞTIĞI KURUMLAR"
            android:textColor="#3A7BD5"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toBottomOf="@id/bookingDoctorCV" />

        <TextView
            android:id="@+id/bookingInstitutions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="6dp"
            android:text="• Kurum Bilgisi"
            android:textColor="#444444"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/lblInstitutions" />

        <TextView
            android:id="@+id/lblArticles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="35dp"
            android:text="YAYINLAR VE ARAŞTIRMALAR"
            android:textColor="#3A7BD5"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toBottomOf="@id/bookingInstitutions" />

        <TextView
            android:id="@+id/bookingArticles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="6dp"
            android:text="• Makale Bilgisi"
            android:textColor="#444444"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/lblArticles" />

        <Button
            android:id="@+id/btnMakeAppointment"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginTop="50dp"
            android:layout_marginBottom="20dp"
            android:text="Randevu Al"
            android:textAllCaps="true"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#3A7BD5"
            android:textColor="@android:color/white"
            app:cornerRadius="15dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/bookingArticles"
            app:layout_constraintVertical_bias="1.0" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>